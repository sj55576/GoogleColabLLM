# プロファイル: ollama
# ローカルで動くOllama (OpenAI互換エンドポイント) に接続するための設定です。
#
# 使い方:
#   cp profiles/ollama.env.example profiles/ollama.env
#   ollama pull llama3.2   # 事前に使いたいモデルをpullしておく
#   ./scripts/ask.sh -p ollama "質問文"

# APIのベースURL (Ollamaのデフォルトポート)
LLM_BASE_URL=http://localhost:11434/v1

# modelフィールドに指定する値の例。`ollama list` で確認できるモデル名に変更してください。
LLM_MODEL=llama3.2

# Ollamaは認証を行わないため、形式的な値として直接 "dummy" を書いてよい
# (実際の認証には使われない)。
LLM_API_KEY=dummy

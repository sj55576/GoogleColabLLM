# プロファイル: lmstudio
# LM Studio (ローカルサーバー機能、OpenAI互換API) に接続するための設定です。
#
# 使い方:
#   cp profiles/lmstudio.env.example profiles/lmstudio.env
#   LM Studio アプリの「Local Server」タブでサーバーを起動しておく
#   ./scripts/ask.sh -p lmstudio "質問文"

# APIのベースURL (LM Studioのデフォルトポート)
LLM_BASE_URL=http://localhost:1234/v1

# modelフィールドに指定する値の例。LM Studio上でロードしているモデル名に変更してください。
LLM_MODEL=local-model

# LM Studioのローカルサーバーは認証を行わないため、形式的な値として
# 直接 "dummy" を書いてよい (実際の認証には使われない)。
LLM_API_KEY=dummy

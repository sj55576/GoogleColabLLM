# プロファイル: groq
# Groq (OpenAI互換API) に接続するための設定です。
#
# APIキーの取得方法: https://console.groq.com/keys
#
# 使い方:
#   cp profiles/groq.env.example profiles/groq.env
#   export GROQ_API_KEY="gsk_..."   # キー本体はシェル環境にのみ置く (このファイルには書かない)
#   ./scripts/ask.sh -p groq "質問文"

# APIのベースURL (Groq)
LLM_BASE_URL=https://api.groq.com/openai/v1

# modelフィールドに指定する値の例。必要に応じて他のモデルに変更してください。
LLM_MODEL=llama-3.1-8b-instant

# APIキー本体をこのファイルに書かず、環境変数名だけを指定する方式。
# 実行前に `export GROQ_API_KEY="gsk_..."` しておけば、
# scripts/lib/common.sh が自動的にLLM_API_KEYへ解決します。
LLM_API_KEY_ENV=GROQ_API_KEY

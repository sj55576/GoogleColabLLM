# プロファイル: openrouter
# OpenRouter (OpenAI互換API、複数プロバイダのモデルを集約) に接続するための設定です。
#
# APIキーの取得方法: https://openrouter.ai/keys
#
# 使い方:
#   cp profiles/openrouter.env.example profiles/openrouter.env
#   export OPENROUTER_API_KEY="sk-or-..."   # キー本体はシェル環境にのみ置く (このファイルには書かない)
#   ./scripts/ask.sh -p openrouter "質問文"

# APIのベースURL (OpenRouter)
LLM_BASE_URL=https://openrouter.ai/api/v1

# modelフィールドに指定する値の例。必要に応じて他のモデルに変更してください。
LLM_MODEL=meta-llama/llama-3.1-8b-instruct

# APIキー本体をこのファイルに書かず、環境変数名だけを指定する方式。
# 実行前に `export OPENROUTER_API_KEY="sk-or-..."` しておけば、
# scripts/lib/common.sh が自動的にLLM_API_KEYへ解決します。
LLM_API_KEY_ENV=OPENROUTER_API_KEY

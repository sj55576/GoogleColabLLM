# プロファイル: colab-local
# このリポジトリ本来の使い方 (Colab T4上のllama-cpp-pythonサーバー) 向けの設定です。
# 通常はプロファイルを使わずにデフォルト動作 (無指定) のままでも同じ結果になりますが、
# 明示的に指定したい場合や、他のプロファイルと切り替えながら使いたい場合はこちらを使ってください。
#
# 使い方:
#   cp profiles/colab-local.env.example profiles/colab-local.env
#   ./scripts/ask.sh -p colab-local "質問文"

# APIのベースURL。ポートフォワード/トンネル利用時はそのURLに置き換えてください。
LLM_BASE_URL=http://localhost:8000/v1

# modelフィールドに指定する値。ローカルサーバーではモデル名は実質何でもよい。
LLM_MODEL=local

# APIキー。ローカルのllama-cpp-pythonサーバーは認証を行わないため、
# 形式的な値として直接 "dummy" を書いてよい (実際の認証には使われない)。
LLM_API_KEY=dummy

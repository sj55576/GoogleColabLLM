# プロファイル: openai
# OpenAI公式APIに接続するための設定です。
#
# APIキーの取得方法: https://platform.openai.com/api-keys
#
# 使い方:
#   cp profiles/openai.env.example profiles/openai.env
#   export OPENAI_API_KEY="sk-..."   # キー本体はシェル環境にのみ置く (このファイルには書かない)
#   ./scripts/ask.sh -p openai "質問文"

# APIのベースURL (OpenAI公式)
LLM_BASE_URL=https://api.openai.com/v1

# modelフィールドに指定する値の例。必要に応じて他のモデルに変更してください。
LLM_MODEL=gpt-4o-mini

# APIキー本体をこのファイルに書かず、環境変数名だけを指定する方式。
# 実行前に `export OPENAI_API_KEY="sk-..."` しておけば、
# scripts/lib/common.sh が自動的にLLM_API_KEYへ解決します。
LLM_API_KEY_ENV=OPENAI_API_KEY
